0BLOCK: Procedure expose ($globalv) /* DROP or KEEP block by text or number */
 parse value copies('0 ',20) with ?rest ?from ?to ?fromn ?ton ?count,
  ?after ?aftern ?before ?beforen .
 parse value '' with $what $after $before $from $to $count
 parse arg what prm  0 . p1 p2
 if datatype(prm)='NUM'  then prm='from 1 to' prm
 if translate(p1)='LAST' then prm='from' $stacked-p2+1
 ?keep=(translate(what)='KEEP')
 ?drop=(translate(what)='DROP')
 if ?keep+?drop=0 then call quit 'rc 9 msg Bad 1st parm'
 Interpret Kparse(prm,'after before from to count','$')
 if err<>'' then call quit 'rc 8 msg' err
 ?fromn=(datatype($from)='NUM')
 if \?fromn then ?from  =($from  <>'')
 if \?fromn then $from=UnQuote($from)
 ?ton=(datatype($to)='NUM')
 if \?ton then ?to=($to<>'')
 if \?ton then $to=UnQuote($to)
 ?after=($after<>'')
 if ?after  then $after=UnQuote($after)
 ?before=($before<>'')
 if ?before then $before=UnQuote($before)
 if \?from & \?fromn & \?after  then parse value 1 1 with ?fromn $from
 if \?to   & \?ton   & \?before then parse value 1 $stacked with ?ton $to
 parse value ?drop ?drop with ?put ?putmod
 lr=''                            /* last-rec for BEFORE processing */
 do r#=1 to $stacked
   parse pull r
   zz=r#
   select
     when ?rest then nop
     when ?to & pos($to,r)>0 then,
       parse value 1 (\?putmod) with ?rest ?putmod
     when ?ton & r#=$to then,
       parse value 1 (\?putmod) with ?rest ?putmod
     when ?from & pos($from,r)>0 then do
       parse value 0 (\?put) (\?putmod) with ?from ?put ?putmod
       if $count<>'' then parse value 1 r#+$count-1 with ?ton $to
     end
     when ?fromn & r#=$from then do
       parse value 0 (\?put) (\?putmod) with ?fromn ?put ?putmod
       if $count<>'' then parse value 1 r#+$count-1 with ?ton $to
     end
     when ?after & pos($after,r)>0 then do
       parse value 0 (\?putmod) with ?after ?putmod
       if $count<>'' then parse value 1 r#+$count   with ?ton $to
     end
     when ?before & pos($before,r)>0 then do
       if \?put then queue lr
       parse value 0 (\?put) (\?putmod) with ?before ?put ?putmod
     end
     otherwise nop
   end
   if ?put then queue r
   ?put = ?putmod
   lr=r
 end
 return 0

/* Get dataset information using current stack as input*/
0DSINFO: Procedure expose ($globalv)
 arg $prm
 parse var $prm $f $p ' LIST ' $vl
 if $vl='' then $vl='SYSVOLUME SYSDSORG SYSRECFM'
 $prm=space($f $p)
 $qn=queued()
 do $qn
   pull $ds .
   $cc=Listdsi($ds $p)
   if $cc<>0 then do
     queue 'DSINFO' $ds 'rc' $cc sysreason
     iterate
   end
   $rt=$ds
   do $n=1 to words($vl)
     $rt=$rt value(word($vl,$n))
   end
   queue $rt
 end
 return 0

0JOIN: /* Join stream to stack */
 parse value '1 1 1 1 0' ,
   with $id $outer $o $inner $i $keypos1 $keylen $keypos2
 Interpret KParse('id' arg(1),,
           'outer o inner i keypos1 keypos2 keylen sepc','$',1)
 if $keypos1='' then call Quit 'rc 8 msg Missing keypos'
 $keypos2=word($keypos2 1,1)
 if $keylen ='' then call Quit 'rc 8 msg Missing keylen'
 $id   =word($id 1,1)
 $inner=($inner | $i)
 if \$inner then $outer=($outer | $o)
 $sepc =Unquote($sepc)
 do $=1 to $str.$id.0 /* build key table */
   zz=value('$k.'substr($str.$id.$,$keypos2,$keylen),$)
 end
 do $stacked          /* join by key */
   parse pull $l
   $r=subword(value('$str.'$id'.'value('$k.'substr($l,$keypos1,$keylen))),2)
   if $inner & $r='' then iterate
   queue strip($l) || $sepc || $r
 end
 drop $k.
 return 0

0VTable: return Table('V' arg(1))    /* vertical table */
0TABLE: Procedure expose ($globalv) /* Make horizontal or vertical table */
 parse value 'z z z z',
   with $top $bot $both $bord $orient $cols $width $just $pad
 Interpret KParse('orient' arg(1),,
           'cols width just bord orient top bot both pad','$')
 upper $just $orient $top $bot $both
 $orient =word($orient 'H',1)
 if $both<>'Z' then parse value '' with $top $bot  /* activate both */
 if $bord='' then $bord='|+++'                     /* use default   */
 else if $bord='z' then $bord=''
 parse var $bord $cbc +1 $tbc +1 $tbl +1 $tbr +1 .
 $cbl   =length($cbc)          /* cell border char length */
 $pad   =word($pad '1',1)      /* cell pad length per side */
 $padc  =copies(' ',$pad)      /* cell pad per side        */
 $txtl  =0

 /* move stack to table, get some stats */
 $sn=0
 $s.=''
 do $stacked
   parse pull r
   do $=1 to words(r)
     @=word(r,$)
     $txtl=max($txtl,length(@))
     $sn=$sn+1
     $s.$sn=@
   end
 end
 $s.0=$sn
 if $width<>'' then $txtl=$width
 $cwt  = $txtl+(2*$pad)+$cbl /* cell width */
 if $cols='' then  $cols = ($scrwdth-$cbl-1)%$cwt
 /*$rows = space(format(($s.0%$cols)+0.5,6,0))*/
 $rows = ($s.0+($cols-0.1))%$cols
 if $bord='' then $cf=$cbc
 else $cf  = $cbc || $padc

 /* make top/bottom */
 $line=''
 do $n=1 to $cols
   $line=$line || $tbc || copies('-',$txtl+2)
 end
 $line=$tbl || substr($line,2) || $tbr
 if $bord<>'' & $top<>'Z' then queue $line

 /* build horizontal table */
 if $orient ='H' then do
   $l=''
   do $on=1 to $s.0 by $cols
     do $in=$on to $on+$cols-1
       $l=$l || $cf || TableData($s.$in) || $padc
     end
     queue $l || $cbc
     $l=''
   end
 end

 /* build vartical table */
 if $orient ='V' then do
   $l=''
   do $on=1 to $rows
     $cn=0
     do $in=$on to $s.0 by $rows
       $cn=$cn+1
     /*$l=$l || $cbc || $padc || TableData($s.$in) || $padc   */
       $l=$l || $cf || TableData($s.$in) || $padc
     end
     do $n=$cn+1 to $cols      /* column might be missing */
       $l=$l || $cf || left(' ',$txtl) || $padc
     end
     queue $l || $cbc
     $l=''
   end
 end

 if $bord<>'' & $bot<>'Z' then queue $line
 return 0
TableData:
trace off
 Select
   when $just='L' then return left(arg(1),$txtl)
   when $just='R' then return right(arg(1),$txtl)
   when $just='C' then return center(arg(1),$txtl)
   when $just='A' then do
     if datatype(arg(1))='NUM' then return right(arg(1),$txtl)
     else return left(arg(1),$txtl)
   end
   otherwise return left(arg(1),$txtl)
 end
 Call Quit 'rc 20 msg Internal error 1 for TableData'

