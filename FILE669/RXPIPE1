 $version='006.06 2023-07-13'
 parse source @sys @what @me @ddn @where .
 if abbrev('VERSION',translate(arg(1)),3) then do
   if @what='FUNCTION' then return $version
   exit Xmsg(@me $version)
 end
 if arg(1)='' then exit Xmsg(@me $version 'Some sort of input is required')

 /*                       - GO -                                      */
 /*Interpret RxpiInit()  */   /* future */
 Address TSO
 ?bg = left(sysvar('sysenv'),1)<>'F'  /* Fore/Back */
 ?ISPF=(Sysvar('SYSISPF')='ACTIVE')
 if ?ispf then do
   Address Ispexec "Control errors return"
   Address Ispexec "vget zscrmaxw"
   $scrwdth=zscrmaxw
 end
 else $scrwdth=80

 $vcl='abcdefghijklmnopqrstuvwxyz'
 $vcl=$vcl||translate($vcl)'0123456789$@#'
 $cval='CLEAR 2 DSNLIST 4 FILTER 2 LIST 1 TERMINAL 4',  /* abbreviations */
       'REPLACE 4 MBRLIST 4 READ 1 WRITE 1 CATSEARCH 4 PDSLIST 4',
       'INCLUDE 3 EXCLUDE 3 COMBINE 4 COMPARE 4 SKELETON 4'
 $cvrbtri='zSTRIP'                      /* change command to internal     */
 $cvrbtro='zSTRIPC'                     /* to avoid confusion             */
 parse value '| & \' with $sepc $and $escc $lastdd $lastcmd,
  $haltonrc
 parse value 1 1 1 copies('0 ',20) with $ifcond $cond. $condlvl,
   $xrc $cmdn $set ?noprefix ?setuserpfx ?retain $icmd. .
 parse value userid() mvsvar('symdef','jobname') Sysvar('SYSPREF'),
   with $user $jobname $userpfx 1 user jobname prefix 1 me .
 Call Xtso "listc ent('SYS1.PARMLIB')"
 mcatname=word($.2,3)
 Call Xtso "listc ent('"mcatname"') vol"
 n=$.0
 mcatvol=word(translate($.n,' ','-'),2)

 $pcmd = strip(arg(1))
 if Verify($pcmd,'0203040506070809'x,'m') then,
   call quit 'rc 8 msg Command contains restricted chars 02-09x'
 if left($pcmd,1)='"' then $pcmd = strip(arg(1),'b','"')
 if left($pcmd,1)="'" then $pcmd = strip(arg(1),"b","'")
 $pcmd = strip($pcmd)
 $globalv='?ispf $xrc $initstack# $stacked $lastdd $lastcmd $scrwdth',
          '$userpfx ?setuserpfx ?rxpattrn ?retain $escc'

 /* make list of internal commands */
 n=0
 do $=1 to Sourceline()
   w=word(sourceline($),1)
   if left(w,1)<>'0' then iterate
   w=translate(space(translate(w,' ',':')))
   parse value translate(w) with =2 w ':' .
   $icmd.w=1
   n=n+1
 end
 if n=0 then exit xmsg('No internal commands found*****')+20
 /*call rexxvars 'list var($icmd*)'*/

 /* handle initial stack */
 $initstack#=StackNum()
 if left($pcmd,1)=$sepc then do             /* use callers stack         */
   $pcmd=substr($pcmd,2)                    /* drop pipe separator       */
   Call 0SAVE '0 stacked' queued() 'CLEAR'
   "newstack"
   Call 0LOAD '0'
   drop $str.
 end                                        /* no initial, just make new */
 else "newstack"

 /*====================================================================

   Process command stream
   Each command is separated by the command delimiter

 ====================================================================*/
 Call SetNoPrefix
 Do while $pcmd<>''
trace off
   $cmdn = $cmdn+1
   $pcmd = strip($pcmd)
   /* redefine delimiter */
   if translate(word($pcmd,1))='SEPC' then do
     parse value delword($pcmd,1,1) with $sepc +1 $pcmd
     $pcmd = strip($pcmd)
   end
   if translate(word($pcmd,1))<>'QUIT' then,
     ?retain = (right($pcmd,1)=$sepc)
   /* locate next delimiter, convert escaped dlms to text  */
   $p=verify($pcmd,"' "$sepc,'n')         /* beware of     */
   if $p>1 then $pcmd=substr($pcmd,$p)    /* null commands */
   $p = 1
   do $n=1 to 9999
     /* ignore delimiters inside quotes */
     do forever
       $p=verify($pcmd,"'"$sepc,'m',$p)
       if $p=0 then leave
       if substr($pcmd,$p,1)=$sepc then leave
       $p=pos("'",$pcmd,$p+1)             /* locate end of quote */
       if $p=0 then call quit 'rc 8 msg **no end quote'
       $p=$p+1
     end
     if $p=0 then do
       $p=length($pcmd)+1
       leave $n
     end
     if substr($pcmd,$p-1,1)=$escc then do
       $pcmd=delstr($pcmd,$p-1,1)
       iterate $n
     end
     leave $n
   end
   parse var $pcmd $cmd =($p) +1 $pcmd
   $cmd=strip($cmd)
   if $pcmd='' then $pcmd='Quit'

   if $cmd='' then iterate   /* beware of null */

   /* call processor                  */
   $cmdsave=$cmd
   parse var $cmd $cmdverb $cmddata
   upper $cmdverb

   /* handle conditional execution */
   if translate(word($cmd,1))='ELSE' then do
     $cond.$condlvl=\$cond.$condlvl
     if words($cmd)>1 then do
       $p=subword($cmd,2)       /* drop ELSE */
       if translate(word($pcmd,1))<>'END' then,
         $pcmd=$p $sepc 'END' $sepc $pcmd
       else $pcmd=$p $sepc $pcmd
     end
   end
   if translate($cmd)='END'  then $condlvl=$condlvl-1
   if $condlvl>1 & pos($sepc,$pcmd)=0 then,
     call quit 'rc 8 msg missing END command'
   if $cond.$condlvl then Call RunCmd /* conditional section start */

 End
 Call Quit

RunCmd:
 trace off
 parse value 0 0 queued() StackNum() with,
   ?build ?where $stacked $stacknum $vv
 /* some special character commands */
 $c=$cmdverb $cmddata
 select
   when $c='>' then Call Quit 'RETAIN' /* quit, leave stack */
   when left($c,1)='<' then do
     if datatype(word(substr($c,2),1))='NUM' then,
       $c='LOAD' space(substr($c,2))
     else $c='READ' strip(substr($c,2))
   end
   when left($c,2)='>>' then $c='WRITE' strip(substr($c,3)) 'APPEND'
   when left($c,1)='>'    then do
     if datatype(space(substr($c,2)))='NUM' then,
       $c='SAVE' space(substr($c,2)) 'CLEAR'
     else $c='WRITE' strip(substr($c,2))
   end
   otherwise nop
 end
 parse var $c $cmdverb $cmddata

 /* get real cmdverb */
 do $=1 to words($cval) by 2 while $vv=''
   parse value subword($cval,$,2) with $v $l .
   if abbrev($v,$cmdverb,$l) then $vv=$v
 end
 if $vv<>'' then $cmdverb=$v

 parse value '' with  $build $where
 $cmddata=vsub($cmddata)
 $=wordpos($cmdverb,$cvrbtri)                /* beware of some commands */
 if $>0 then $cmdverb=word($cvrbtro,$)       /* same as REXX functions  */
 upper $cmdverb
 $cmd=$cmdverb $cmddata
 $cmddata=strip($cmddata)

 parse value 0 with $rc result $result
 /* internal */
 if $icmd.$cmdverb then do                   /* detected internal command */
   Interpret "result=0"$cmdverb"($cmddata)"
   Return RunCmdResult()
 end
 /* external */
 signal on syntax name RunCmdSyntax
 /*if left($cmd,1)='%' then ""$cmd
 else */result=XtsoStack($cmd)
 if result>=0 then Return RunCmdResult()
 $zrc=result
 Call 0FILTER 'NOTNULL'
 r=''
 if queued()>0 then do
   parse pull r
   r='text' r
 end
 call Quit 'rc 8 msg cc' space($zrc 'after' $cmd r)

RunCmdSyntax:
 zz=outtrap('off')  /* just in case */
 say 'Cmd error' rc 'for' $cmd
 Return RunCmdResult()

RunCmdResult:
 trace off
 signal off syntax
 if Symbol('RESULT')='VAR' then $result=result
 if datatype($result)='NUM' then $rc=$result
 $lastcmd=$cmdverb
 if $haltonrc<>'' then,
   if $rc>=$haltonrc then call quit 'rc 8 msg Halt on' $cmdverb 'cc' $rc
 return 0

