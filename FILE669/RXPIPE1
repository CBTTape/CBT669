 $l1=length($p1)
 $l2=length($p2)
 $c="do $stacked;Call PullParse;"
 if $where<>'' then $c=$c "if" $where "then do;"
 $c=$c "$=1;do forever;$=pos($p1,r,$);if $=0 then leave;",
    "r=left(r,$-1) || $p2 || substr(r,$+"$l1");$=$+"$l2";end;"
