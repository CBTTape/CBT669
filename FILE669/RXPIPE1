Requote: if arg(1)='' then return '';else return "'"Unquote(arg(1))"'"
UnQuote: trace off; return, /* drop outer quotes, preserve inner blanks */
 translate(strip(strip(translate(arg(1),'04'x,' '),"b","'"),'b'),' ','04'x)
